# === Окружение worker'а ===
ENV=dev

# === Логи ===
# debug | info | warn | error
LOG_LEVEL=info

# === Sentry (опционально) ===
# При пустом значении Sentry не инициализируется.
SENTRY_DSN=

# === HTTP ===
LLM_WORKER_HTTP_HOST=
LLM_WORKER_HTTP_PORT=8081

# ============================================================================
# CLAUDE.md инвариант №5: ANTHROPIC_API_KEY и UID_HASH_PEPPER хранятся
# ТОЛЬКО здесь, в env worker'а — основной бэкенд (cmd/api) их не знает.
# В dev без ключа worker работает в echo-режиме; при ENV=prod ключ обязателен
# (иначе старт падает). Подробный runbook — backend/README.md §«Регистрация
# внешних аккаунтов» (часть B: Anthropic).
# ============================================================================

# === Anthropic (Этап 2.2) ===
# Production-ключ. Bedrock/Vertex недоступны из РФ-инфры (ARCH §11.1) —
# worker идёт напрямую к api.anthropic.com через иностранный VPS.
# Пусто в dev → echo-провайдер; обязателен при ENV=prod.
ANTHROPIC_API_KEY=

# Потолок output-токенов на ответ Claude.
WORKER_MAX_TOKENS=2048

# Аварийный override модели (важнее model из payload). Пусто → берём из payload
# (РФ-бэкенд шлёт llm.DefaultModel = claude-opus-4-7).
# ANTHROPIC_MODEL=

# === UID hash pepper (Этап 2.3) ===
# Соль для sha256(uid+pepper), под этим хэшем worker логирует пользователя
# в метаданных Anthropic. Совпадает с UID_HASH_PEPPER на бэкенде.
# UID_HASH_PEPPER=

# === Backend callback (Этап 5.2) ===
# Куда worker делает tool-callback (recommend_fertilizer) обратно в РФ-бэкенд.
# В prod — приватный mTLS-эндпоинт. См. ARCH §11.3.
# BACKEND_CALLBACK_URL=https://api.agronomai.site:8443/internal/v1/tools/fertilizer

# ============================================================================
# В prod-окружении mTLS терминируется Caddy перед worker'ом (см.
# infra/docker/compose/prod-llmworker.Caddyfile). Сам worker слушает чистый
# HTTP внутри VM, поэтому переменные путей до cert/key/CA — это конфиг
# Caddy, не worker'а. Worker про TLS ничего не знает.
# ============================================================================
