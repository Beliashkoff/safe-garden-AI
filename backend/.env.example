# === Окружение ===
ENV=dev

# === HTTP ===
HTTP_HOST=
HTTP_PORT=8080

# === Логи ===
# debug | info | warn | error
LOG_LEVEL=info

# === Sentry (опционально) ===
# При пустом значении Sentry не инициализируется.
SENTRY_DSN=

# ============================================================================
# Ниже — placeholder'ы под ключи Этапа 0.6 (внешние аккаунты заказчика).
# Некоторые активированы на Этапе 1.1 (auth-фундамент), остальные —
# закомментированы до соответствующего этапа.
# Подробный runbook по получению — в README.md, раздел
# «Регистрация внешних аккаунтов».
#
# Секреты никогда не коммитим. Хранение — в password manager заказчика
# (1Password / Bitwarden / Yandex Vault) и в Yandex Lockbox в prod.
# ============================================================================

# === Postgres (Этап 1.1) ===
POSTGRES_DSN=postgres://safegarden:safegarden@localhost:5432/safegarden?sslmode=disable

# === JWT (Этап 1.1) ===
# Мульти-ключевая ротация (рекомендуется): директория с PEM-файлами
# вида <kid>.pem (PKCS#8 RSA private). На подпись идёт ключ JWT_ACTIVE_KID;
# все ключи в директории доступны для verify (grace-период ≈ access TTL).
JWT_KEYS_DIR=./dev-keys
JWT_ACTIVE_KID=dev1
# Альтернатива (упрощённый dev-вариант, один ключ):
# JWT_PRIVATE_KEY_PATH=/secrets/jwt-rs256.pem
# JWT_KID=2026-05
# Время жизни access/refresh — переопределяется только если нужно отойти
# от ARCHITECTURE §8.1 (15m / 30d).
# JWT_ACCESS_TTL=15m
# REFRESH_TTL=720h

# === OIDC: Apple (Этап 1.1) ===
# Bundle ID iOS-приложения (audience id_token). Без него Apple-вход не работает.
APPLE_BUNDLE_ID=
# Используется на Этапе 1.2 (DELETE /v1/account вызывает Apple revoke endpoint).
# APPLE_TEAM_ID=
# APPLE_KEY_ID=
# APPLE_PRIVATE_KEY_PATH=/secrets/apple-signin.p8

# === OIDC: Google (Этап 1.1) ===
# Хотя бы один из трёх обязателен в prod. Allowlist для aud в id_token.
# WEB-клиент используется мобильным google_sign_in как serverClientId,
# поэтому aud в id_token будет равен GOOGLE_CLIENT_ID_WEB (Этап 1.5).
GOOGLE_CLIENT_ID_IOS=
GOOGLE_CLIENT_ID_ANDROID=
GOOGLE_CLIENT_ID_WEB=

# === Redis (Этап 2.3) ===
# Per-user rate limit на POST /v1/messages (20 RPS, ARCH §8.2). В dev — redis из
# docker-compose; пусто → rate limit отключён (allow-all). В prod обязателен.
REDIS_ADDR=localhost:6379
# REDIS_PASSWORD=

# === UID hash pepper (Этап 2.3) ===
# Соль для uid_hash = sha256(user_id + pepper) — единственный идентификатор
# пользователя, уходящий в worker/Anthropic (ARCH §11.4, §8.6). Обязателен в prod.
# Совпадает с UID_HASH_PEPPER в env worker'а.
UID_HASH_PEPPER=dev-pepper-change-me

# === Object Storage (Этап 3.1) ===
# В dev — MinIO (см. docker-compose.yml: minioadmin / minioadmin).
# В prod — Yandex Object Storage, креды из Yandex Cloud service account.
# S3_ENDPOINT=http://localhost:9000
# S3_REGION=ru-central1
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_BUCKET=safe-garden-dev-media

# === SMTP — Mailer для OTP (Этап 1.2) ===
# Dev по умолчанию шлёт в MailHog из docker-compose (localhost:1025, без auth
# и TLS) — письма видны в http://localhost:8025. Значения ниже переопределять
# в dev не нужно; они показаны для наглядности.
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=noreply@localhost
SMTP_FROM_NAME=Safe Garden AI
SMTP_TLS=false
# SMTP_USERNAME=
# SMTP_PASSWORD=
#
# Prod — Yandex 360. Хост/порт фиксированы; SMTP_TLS=true (implicit TLS на 465).
# Username — почтовый адрес; password — пароль приложения из настроек ящика,
# не основной пароль. SMTP_USERNAME/SMTP_PASSWORD/SMTP_FROM обязательны в prod.
# SMTP_HOST=smtp.yandex.ru
# SMTP_PORT=465
# SMTP_TLS=true
# SMTP_USERNAME=noreply@agronomai.site
# SMTP_PASSWORD=
# SMTP_FROM=noreply@agronomai.site

# === Swagger UI / OpenAPI (Этап 1.2) ===
# Отдаёт спецификацию и Swagger UI на /v1/docs. Можно выключить в prod.
DOCS_ENABLED=true

# === LLM-клиент (Этап 0.7+) ===
# Выбор реализации llm.Client:
#   - mock   — фикстуры из internal/llm/mock_client.go (по умолчанию в dev/тестах)
#   - worker — реальный HTTP+SSE к llm-worker'у через mTLS (prod)
LLM_CLIENT_KIND=mock

# === LLM-worker (Этап 2.2) ===
# Используется, когда LLM_CLIENT_KIND=worker. ANTHROPIC_API_KEY и
# UID_HASH_PEPPER сюда НЕ кладём — они переменные worker'а
# (`internal/llmworker/`, см. backend/.env.worker.example). CLAUDE.md инвариант №5.
# LLM_WORKER_BASE_URL=https://worker.agronomai.site
# LLM_WORKER_MTLS_ENABLED=true
# LLM_WORKER_CA_PATH=/secrets/mtls/ca.pem
# LLM_WORKER_CLIENT_CERT_PATH=/secrets/mtls/api-client.crt
# LLM_WORKER_CLIENT_KEY_PATH=/secrets/mtls/api-client.key

# === Yandex SpeechKit (Этап 4.2) ===
# YANDEX_SPEECHKIT_API_KEY=
