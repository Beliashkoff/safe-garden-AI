# Caddy для api.agronomai.site. Auto-HTTPS через Let's Encrypt.
# Подменяется при деплое: $DOMAIN передаётся через env.

{$DOMAIN} {
	encode gzip zstd

	reverse_proxy api:8080 {
		health_uri /healthz
		health_interval 30s
		health_timeout 3s
	}

	log {
		output stdout
		format json
		level INFO
	}

	header {
		Strict-Transport-Security "max-age=63072000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "no-referrer"
		-Server
	}
}
